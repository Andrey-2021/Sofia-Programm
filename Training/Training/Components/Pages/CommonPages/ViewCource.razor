@page "/test"
<div class="container">
    <div class="course-card">
        <!-- Заголовок карточки -->
        <div class="card-header">
            <h1 class="course-name">
                Японский язык для начинающих
            </h1>
            <div class="course-meta">
                <div class="meta-item">
                    📅 10 февраля 2025
                </div>
                <div class="meta-item">
                    ⏱️ 9 часов
                </div>
            </div>
        </div>

        <!-- Тело карточки -->
        <div class="card-body">
            <!-- Описание курса -->
            <div class="section">
                <div class="section-title">
                    📖 Описание курса
                </div>
                <div class="description">
                    Интенсивный курс по основам японской письменности.
                    Изучим хирагану, катакану, базовые кандзи и отработку лексики
                    на реальных примерах. Курс подходит для самостоятельного изучения
                    или занятий в группе с преподавателем.
                </div>
            </div>

            <!-- Характеристики курса -->
            <div class="section">
                <div class="section-title">
                    ⚙️ Характеристики
                </div>
                <div class="info-grid">
                    <!-- Уровень сложности -->
                    <div class="info-item">
                        <div class="info-label">
                            🎯 Уровень сложности
                        </div>
                        <div class="info-value">
                            <div class="stars">
                                <span class="star star-filled">★</span>
                                <span class="star star-filled">★</span>
                                <span class="star star-filled">★</span>
                                <span class="star star-empty">☆</span>
                                <span class="star star-empty">☆</span>
                            </div>
                            <div style="margin-top: 8px; font-size: 12px; color: #718096;">
                                3 из 5
                            </div>
                        </div>
                    </div>

                    <!-- Доступность -->
                    <div class="info-item">
                        <div class="info-label">
                            🌐 Доступность
                        </div>
                        <div class="info-value">
                            <span class="badge badge-public">
                                👁️ Доступен всем
                            </span>
                        </div>
                    </div>

                    <!-- Продолжительность -->
                    <div class="info-item">
                        <div class="info-label">
                            ⏰ Продолжительность
                        </div>
                        <div class="info-value">
                            <div>540 минут</div>
                            <div style="font-size: 12px; color: #718096; margin-top: 5px;">
                                9 часов
                            </div>
                        </div>
                    </div>

                    <!-- Дата создания -->
                    <div class="info-item">
                        <div class="info-label">
                            📅 Дата создания
                        </div>
                        <div class="info-value">
                            <div>10 февраля 2025</div>
                            <div style="font-size: 12px; color: #718096; margin-top: 5px;">
                                10.02.2025
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Управление вопросами курса -->
            <div class="questions-control">
                <div class="control-blocks">
                    <!-- Блок 1: Интервал -->
                    <div class="control-block">
                        <div class="block-title">
                            Интервал
                        </div>
                        <div>
                            <input type="number" class="interval-input" value="3" step="0.5" min="0.5">
                            <span class="interval-unit">сек</span>
                        </div>
                    </div>

                    <!-- Блок 2: Автопрокрутка -->
                    <div class="control-block">
                        <div class="block-title">
                            Автопрокрутка
                        </div>
                        <div>
                            <label class="toggle-switch">
                                <input type="checkbox" id="autoToggle">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>

                    <!-- Блок 3: Навигация -->
                    <div class="control-block">
                        <div class="block-title">
                            Навигация
                        </div>
                        <div class="nav-buttons">
                            <button class="btn btn-stop">
                                <div class="btn-text">
                                    <span>
                                        ⏹️
                                    </span>
                                    <span>
                                        Стоп
                                    </span>
                                </div>
                            </button>
                            <button class="btn btn-first">
                                <div class="btn-text">
                                    <span>⏮️</span>
                                    <span>К&ensp;</span><span>первому</span>
                                    </div>
                            </button>
                            <button class="btn btn-last">
                                <div class="btn-text">
                                    <span>К&ensp;</span>
                                    <span>последнему</span>
                                    <span>⏭️</span>
                                </div>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>




        <div class="question-card">
            <div class="question-header">
                <span class="question-counter">Вопрос №1 из 20</span>
            </div>
    
            <div class="question-content">
                <div class="question-row">
                    <div class="question-field">
                        <div class="field-label">Кандзи</div>
                        <div class="field-value kanji-text">学</div>
                    </div>
            
                    <div class="question-field">
                        <div class="field-label">Хирагана</div>
                        <div class="field-value">がく</div>
                    </div>
            
                    <div class="question-field">
                        <div class="field-label">Катакана</div>
                        <div class="field-value">ガク</div>
                    </div>
            
                    <div class="question-field">
                        <div class="field-label">🇷🇺 Русское слово</div>
                        <div class="field-value russian-text">учиться, учёба</div>
                    </div>
                </div>
            </div>
        </div>









        <!-- Подвал карточки -->
        <div class="card-footer">
            🎓 Учебная платформа | Данные актуальны на текущий момент
        </div>
    </div>
</div>