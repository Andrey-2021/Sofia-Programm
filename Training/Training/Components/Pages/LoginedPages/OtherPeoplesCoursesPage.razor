@using Entities.Enums
@using Training.Components.Pages.Components
@attribute [Route(ProjectRouters.otherPeoplesCoursesPage)]
@inherits OtherPeoplesCoursesPageModel
<PageTitle>Открытые курсы</PageTitle>
<ShowOperrationErrorComponent BaseOperationResponce="LoadOtherPeoplesCoursesResponce" />
<ShowOperrationErrorComponent BaseOperationResponce="DelSelectedOtherPeopleCourseOperationResponce" />

<RadzenTabs @bind-SelectedIndex=@selectedIndex>
    <Tabs>
        <RadzenTabsItem Text="Курсы открытые для всех. Разработанные другими пользователями.">
            @if (NotSelectedOtherPeopleCourse == null)
            {
                <div>
                    Нет курсов
                </div>
            }
            else
            {
                <ShowAllTrainingCoursesComponent TrainingCourses=@NotSelectedOtherPeopleCourse
                                                 MyUser=@MyUser
                                                 IsMyTrainingCoursesPage="false"
                                                 IsShowDelButton="false"
                                                 OnAddTrainingCourseCallback="OnAddTrainingCourseClick" />
            }
        </RadzenTabsItem>

        <RadzenTabsItem Text="Уже мною выбранные чужие курсы (разработанные другими пользователями)">
            <ShowOperrationErrorComponent BaseOperationResponce="DelSelectedOtherPeopleCourseOperationResponce" />
            <ShowAllTrainingCoursesComponent TrainingCourses=@SelectedOtherPeopleCourse
                                             MyUser=@MyUser
                                             IsMyTrainingCoursesPage="false"
                                             IsShowDelButton="true"
                                             OnDeleteTrainingCourseCallback="DeleteSelectedTrainingCourse" />
        </RadzenTabsItem>
        
    </Tabs>
</RadzenTabs>

@code {
    int selectedIndex = 0;
}