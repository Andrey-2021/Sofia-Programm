@using Training.Components.Pages.Components
@using Training.Components.Pages.LoginedPages
@attribute [Route(ProjectRouters.viewTrainingCourcePage)]
@inherits ViewTrainingCourcePageModel

<PageTitle>Курс</PageTitle>

@if (MainEntity == null)
{
    <div>
        Чтение данных
    </div>
}
else
{
    <div class="container">
        <div class="course-card">
            <!-- Заголовок карточки -->
            <div class="card-header">
                <h1 class="course-name">
                    @(MainEntity?.Name)
                </h1>
                <div class="course-meta">
                    <div class="meta-item">
                        📅 @(MainEntity?.ContractDate.ToLongDateString())
                    </div>
                    <div class="meta-item">
                        ⏱️ @MainEntity?.DurationHours минут
                    </div>
                </div>
            </div>

            <!-- Тело карточки -->
            <div class="card-body">
                <!-- Описание курса -->
                <div class="section">
                    <div class="section-title">
                        📖 Описание курса
                    </div>
                    <div class="description">
                        @(MainEntity?.Description)
                    </div>
                </div>

                <!-- Характеристики курса -->
                <div class="section">
                    <div class="section-title">
                        ⚙️ Характеристики
                    </div>
                    <div class="info-grid">
                        <!-- Уровень сложности -->
                        <div class="info-item">
                            <div class="info-label">
                                🎯 Уровень сложности
                            </div>
                            <div class="info-value">
                                <div class="stars">
                                    @for (int i = 0; i < @MainEntity?.DifficultyLevel; i++)
                                    {
                                        <span class="star star-filled">★</span>
                                    }

                                    @for (int i = 0; i < LengthConstants.courceDifficultyLevelLength - MainEntity?.DifficultyLevel; i++)
                                    {
                                        <span class="star star-empty">☆</span>
                                    }

                                    @*  <span class="star star-filled">★</span>
                                <span class="star star-filled">★</span>
                                <span class="star star-filled">★</span>
                                <span class="star star-empty">☆</span>
                                <span class="star star-empty">☆</span> *@
                                </div>
                                <div style="margin-top: 8px; font-size: 12px; color: #718096;">
                                    @(MainEntity?.DifficultyLevel) из @(LengthConstants.courceDifficultyLevelLength)
                                </div>
                            </div>
                        </div>

                        <!-- Доступность -->
                        <div class="info-item">
                            <div class="info-label">
                                🌐 Доступность
                            </div>
                            <div class="info-value">
                                @if (MainEntity?.IsVisableForAll == true)
                                {
                                    <span class="badge badge-public">
                                        👁️ Доступен всем
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-private">
                                        👁️ Недоступен
                                    </span>
                                }


                            </div>
                        </div>

                        <!-- Продолжительность -->
                        <div class="info-item">
                            <div class="info-label">
                                ⏰ Продолжительность
                            </div>
                            <div class="info-value">
                                <div>@(MainEntity?.DurationHours) минут</div>
                                <div style="font-size: 12px; color: #718096; margin-top: 5px;">
                                    @(string.Format("{0:f2}", MainEntity?.DurationHours / 60.0)) часов
                                </div>
                            </div>
                        </div>

                        <!-- Дата создания -->
                        <div class="info-item">
                            <div class="info-label">
                                📅 Дата создания
                            </div>
                            <div class="info-value">
                                <div>@(MainEntity!.ContractDate.ToLongDateString())</div>
                                <div style="font-size: 12px; color: #718096; margin-top: 5px;">
                                    @(MainEntity!.ContractDate.ToShortDateString())
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Управление вопросами курса -->
                <div class="questions-control">
                    <div class="control-blocks">
                        <!-- Блок 1: Интервал -->
                        <div class="control-block">
                            <div class="block-title">
                                Интервал
                            </div>
                            <div>
                                <input type="number" class="interval-input" step="1" min="1"
                                       @bind-value=@interval />
                                <span class="interval-unit">мс.</span>
                            </div>
                        </div>

                        <!-- Блок 2: № карточки -->
                        <div class="control-block">
                            <div class="block-title">
                                № Карточки
                            </div>
                            <div>
                                <input type="number" class="interval-input"
                                       step="1" min="1" max="@MainEntity.CourseQestions?.Count"
                                       @bind-value=@SelectedNumber />
                            </div>
                        </div>

                        <!-- Блок 2: Автопрокрутка -->
                        <div class="control-block">
                            <div class="block-title">
                                Автопрокрутка
                            </div>
                            <div>
                                <label class="toggle-switch">
                                    <input type="checkbox" checked="@Auto" @oninput="CheckboxChanged" />
                                    <span class="toggle-slider"></span>
                                </label>
                            </div>
                        </div>

                        <!-- Блок 3: Навигация -->
                        <div class="control-block">
                            <div class="block-title">
                                Навигация
                            </div>
                            <div class="nav-buttons">
                                <button class=@($"btn {(started == true ? "btn-stop" : "btn-last")}")
                                        @onclick="@Toggle">
                                    <div class="btn-text">
                                        <span>
                                            ⏹️
                                        </span>
                                        <span>
                                            @toggleText
                                        </span>
                                    </div>
                                </button>
                                <button class="btn btn-first" @onclick="@GoToFirst">
                                    <div class="btn-text">
                                        <span>⏮️</span>
                                        <span>К&ensp;</span><span>первому</span>
                                    </div>
                                </button>

                                <button class="btn btn-last"
                                        @onclick="@GoToEnd">
                                    <div class="btn-text">
                                        <span>К&ensp;</span>
                                        <span>последнему</span>
                                        <span>⏭️</span>
                                    </div>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* Карусель карточек *@
            <RadzenCarousel @ref=carousel
                            @bind-SelectedIndex="@selectedIndex"
                            Auto="@Auto"
                            Interval="@interval"
                            AnimationDuration="@animationDuration"
                            PagerOverlay="false"
                            ButtonShade="Shade.Default"
                            Style="height:300px; width:100%;"
                            Change="@(args => OnChange())"
                            AllowPaging="@AllowPaging">
                <Items>
                    @if (MainEntity?.CourseQestions?.Count > 0)
                    {

                        @for (int i = 0; i < MainEntity.CourseQestions.Count; i++)
                        {
                            var orderID = MainEntity.CourseQestions[i];
                            var number = i + 1;
                            <RadzenCarouselItem>
                                <div class="question-card">
                                    <div class="question-header">
                                        <span class="question-counter">Карточка №@(number) из @(MainEntity.CourseQestions.Count)</span>
                                    </div>

                                    <div class="question-content">
                                        <div class="question-row">
                                            <div class="question-field">
                                                <div class="field-label">Кандзи</div>
                                                <div class="field-value kanji-text">@orderID.KanjiWord</div>
                                            </div>

                                            <div class="question-field">
                                                <div class="field-label">Хирагана</div>
                                                <div class="field-value">@orderID.HiraganaWord</div>
                                            </div>

                                            <div class="question-field">
                                                <div class="field-label">Катакана</div>
                                                <div class="field-value">@orderID.KatakanaWord</div>
                                            </div>

                                            <div class="question-field">
                                                <div class="field-label">Слово</div>
                                                <div class="field-value russian-text">@orderID.Word</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </RadzenCarouselItem>
                        }
                    }
                </Items>
            </RadzenCarousel>
        </div>
    </div>
}
