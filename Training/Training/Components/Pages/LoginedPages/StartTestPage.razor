@attribute [Route(ProjectRouters.startTestPage)]
@inherits StartTestPageModel
<PageTitle>Тестирование</PageTitle>
<ShowOperrationErrorComponent BaseOperationResponce="LoadEntityOperationResponce" />
<ShowOperrationErrorComponent BaseOperationResponce="SaveEntityOperationResponce" />

@if (TestHelper == null || TestHelper.MainEntity == null)
{
    <div>
        Нет курса
    </div>
}
else
{
    <div class="container">
        <!-- Шапка с информацией о курсе и статистикой -->
        <div class="course-header">
            <h1 class="course-title">📚 @(TestHelper.MainEntity?.Name)</h1>
            <p class="course-description">
                @(TestHelper.MainEntity?.Description)
            </p>
            <div class="course-meta">
                <span class="meta-item">📅 Создан: @(TestHelper.MainEntity?.ContractDate.ToLongDateString())</span>
                <span class="meta-item">⏱️ Длительность: @(TestHelper.MainEntity?.DurationHours) минут</span>
                <span class="meta-item">🎯 Уровень: @(TestHelper.MainEntity?.DifficultyLevel) из @(LengthConstants.courceDifficultyLevelLength)</span>
                <span class="meta-item">
                    👁️
                    @if (TestHelper.MainEntity?.IsVisableForAll == true)
                    {
                        <span>Доступен всем</span>
                    }
                    else
                    {
                        <span>Не доступен всем</span>
                    }

                </span>

                <span class="meta-item">
                    ⏱️ Время: @(TestHelper.Time)
                </span>
            </div>
        </div>


        <!-- Карточка вопроса -->
        <div class="question-card">
            @if (TestHelper.CurrentQestionIndex + 1 <= TestHelper.QestionNumber && !TestHelper.IsAnswerSelected)
            {
                <!-- Номер вопроса вверху -->
                <div class="question-number">
                    Карточка №@(TestHelper.CurrentQestionIndex + 1) из @(TestHelper.QestionNumber)
                </div>

                <!-- Японские слова в одну строку -->
                <div class="japanese-row">
                    <div class="japanese-item">
                        <div class="japanese-label">КАНДЗИ</div>
                        <div class="japanese-text">@TestHelper.CurrentCourseQestion?.KanjiWord</div>
                    </div>
                    <div class="japanese-item">
                        <div class="japanese-label">ХИРАГАНА</div>
                        <div class="japanese-text">@TestHelper.CurrentCourseQestion?.HiraganaWord</div>
                    </div>
                    <div class="japanese-item">
                        <div class="japanese-label">КАТАКАНА</div>
                        <div class="japanese-text">@TestHelper.CurrentCourseQestion?.KatakanaWord</div>
                    </div>
                </div>

                <!-- Варианты ответов -->
                <div class="answers-grid">

                    @if (TestHelper.RandomAnswers?.RandomAnswers?.Count() > 0)
                    {
                        @foreach (var item in TestHelper.RandomAnswers.RandomAnswers)
                        {
                            <button class="answer-btn"
                                    @onclick="x => OnAnswerClick(item)"
                                    disabled="@TestHelper.IsAnswerSelected">
                                <span>@item.CurrentAnswerWord</span>
                            </button>
                        }
                    }
                </div>
            }
            else
            {
                @*  @if (TestHelper.CurrentQestionIndex + 1 == TestHelper.QestionNumber)
                {
                    if (TestHelper.IsAnswerSelected)
                    { *@
                <div class="test-completed-card">
                    <div class="completion-icon">🎉</div>
                    <h2 class="completion-title">Тестирование завершено!</h2>
                    <p class="completion-message">Вы успешно прошли тест по японскому языку</p>

                    <div class="result-stats">
                        <div class="result-stat correct-stat">
                            <div class="result-label">✅ Правильные ответы</div>
                            <div class="result-value">@TestHelper.CountCorrectAnswers</div>
                        </div>
                        <div class="result-stat wrong-stat">
                            <div class="result-label">❌ Неправильные ответы</div>
                            <div class="result-value">@TestHelper.CountWrongAnswers</div>
                        </div>
                    </div>

                    <div class="total-stat">
                        <div class="total-label">📊 Всего вопросов</div>
                        <div class="total-value">@(TestHelper.QestionNumber)</div>
                    </div>

                    <div class="percentage">
                        <div class="percentage-label">Результат</div>
                        <div class="percentage-value">@(TestHelper.PercentageResult)%</div>
                    </div>

@*                     <div class="final-time">
                        <span class="final-time-label">⏱️ Время прохождения теста</span>
                        <span class="final-time-value">12:45</span>
                    </div> *@
                </div>


                <button class="close-btn"
                        @onclick=@(() => OnCancelClick())>
                    ✖️ Закрыть
                </button>
                @* }
                } *@
            }
        </div>
    </div>
}
