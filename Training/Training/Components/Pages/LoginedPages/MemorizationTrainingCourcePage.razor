@attribute [Route(ProjectRouters.memorizationTrainingCourcePage)]
@inherits MemorizationTrainingCourcePageModel
<PageTitle>Заучивание</PageTitle>

@if (TestHelper == null || TestHelper.MainEntity == null)
{
    <div>
        Нет курса
    </div>
}
else
{
    <div class="container">
        <!-- Шапка с информацией о курсе и статистикой -->
        <div class="course-header">
            <h1 class="course-title">📚 @(TestHelper.MainEntity?.Name)</h1>
            <p class="course-description">
                @(TestHelper.MainEntity?.Description)
            </p>
            <div class="course-meta">
                <span class="meta-item">📅 Создан: @(TestHelper.MainEntity?.CreateDate.ToLongDateString())</span>
                <span class="meta-item">⏱️ Длительность: @(TestHelper.MainEntity?.Duration) минут</span>
                <span class="meta-item">🎯 Уровень: @(TestHelper.MainEntity?.DifficultyLevel) из @(LengthConstants.courceDifficultyLevelLength)</span>
                <span class="meta-item">
                    👁️
                    @if (TestHelper.MainEntity?.IsVisableForAll == true)
                    {
                        <span>Доступен всем</span>
                    }
                    else
                    {
                        <span>Не доступен всем</span>
                    }

                </span>
            </div>
                <div class="stats">
                    <div class="stat-card">
                        <div class="stat-label">✅ Правильно</div>
                        <div class="stat-value correct">@TestHelper.CountCorrectAnswers</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">❌ Неправильно</div>
                        <div class="stat-value wrong">@(TestHelper.CountWrongAnswers)</div>
                    </div>

                    <div class="stat-card">
                        <div class="timer-label">⏱️ Время прохождения</div>
                    <div class="timer-value">@(TestHelper.Time)</div>
                    </div>

                </div>
        </div>

        <!-- Карточка вопроса -->
        <div class="question-card">
            <!-- Номер вопроса вверху -->
            <div class="question-number">
                Карточка №@(TestHelper.CurrentQestionIndex + 1) из @(TestHelper.QestionNumber)
            </div>

            <!-- Японские слова в одну строку -->
            <div class="japanese-row">
                <div class="japanese-item">
                    <div class="japanese-label">КАНДЗИ</div>
                    <div class="japanese-text">@TestHelper.CurrentCourseQestion?.KanjiWord</div>
                </div>
                <div class="japanese-item">
                    <div class="japanese-label">ХИРАГАНА</div>
                    <div class="japanese-text">@TestHelper.CurrentCourseQestion?.HiraganaWord</div>
                </div>
                <div class="japanese-item">
                    <div class="japanese-label">КАТАКАНА</div>
                    <div class="japanese-text">@TestHelper.CurrentCourseQestion?.KatakanaWord</div>
                </div>
            </div>

            <!-- Варианты ответов -->
            <div class="answers-grid">

                @if (TestHelper.RandomAnswers?.RandomAnswers?.Count() > 0)
                {
                    @foreach (var item in TestHelper.RandomAnswers.RandomAnswers)
                    {
                        <button class=@(TestHelper.IsAnswerSelected == false ?"answer-btn":(TestHelper.SelectedAnswer == item ? (item.IsCorrectAnswer ? "answer-btn correct" : "answer-btn wrong")
                                                                                    : (item.IsCorrectAnswer ? "answer-btn correct-info" : "answer-btn wrong-info")))
                                @onclick="x => TestHelper.OnAnswerClick(item)"
                                disabled="@TestHelper.IsAnswerSelected">
                            <span>@item.CurrentAnswerWord</span>

                            @if (TestHelper.IsAnswerSelected == true)
                            {
                                <!-- Правильный ответ (зелёный со стрелкой) -->
                                @if (TestHelper.SelectedAnswer == item && item.IsCorrectAnswer)
                                {
                                    <span class="answer-icon">✅</span>
                                }
                                <!-- Неправильные ответы -->
                                @if (TestHelper.SelectedAnswer == item && !item.IsCorrectAnswer)
                                {
                                    <span class="answer-icon">❌</span>
                                }

                            }
                            @* <span class="answer-icon"></span> *@
                        </button>
                    }
                }
            </div>

            <!-- Кнопка следующего вопроса -->
            @if (TestHelper.CurrentQestionIndex + 1 < TestHelper.QestionNumber)
            {
                <button class="next-btn"
                        @onclick=@(() => TestHelper.OnNextClick())
                        disabled="@(!TestHelper.IsAnswerSelected)">
                    ➡️ Следующая карточка
                </button>
            }
            else
            {
                if (TestHelper.IsAnswerSelected)
                {
                    <button class="close-btn"
                            @onclick=@(() => OnCancelClick())>
                        ✖️ Закрыть
                    </button>
                }
            }
        </div>
    </div>
}